graph TD
    subgraph Transaction_Sequence [Transaction Sequence]
        Tx1[Tx1] --> Tx2[Tx2] --> Tx3[Tx3] --> Tx4[Tx4] --> Tx5[Tx5] -.-> Txn[Tx_n]
    end

    subgraph BERT4ETH_Embeddings [BERT4ETH Embeddings]
        direction TB
        E1[Counterparty<br/>Direction<br/>Amount<br/>Count<br/>TimeDelta]
        E2[Counterparty<br/>Direction<br/>Amount<br/>Count<br/>TimeDelta]
        E3[Counterparty<br/>Direction<br/>Amount<br/>Count<br/>TimeDelta]
        E4[Counterparty<br/>Direction<br/>Amount<br/>Count<br/>TimeDelta]
        E5[Counterparty<br/>Direction<br/>Amount<br/>Count<br/>TimeDelta]
        En[Counterparty<br/>Direction<br/>Amount<br/>Count<br/>TimeDelta]
    end

    Tx1 --> E1
    Tx2 --> E2
    Tx3 --> E3
    Tx4 --> E4
    Tx5 --> E5
    Txn --> En

    subgraph TCN_Layer [1D-Temporal Convolutional Network]
        TCN1[TCN] --- TCN2[TCN] --- TCN3[TCN] --- TCN4[TCN] --- TCN5[TCN] --- TCNn[TCN]
    end

    E1 --> TCN1
    E2 --> TCN2
    E3 --> TCN3
    E4 --> TCN4
    E5 --> TCN5
    En --> TCNn

    subgraph Reps [Instance Representations]
        h1[h1]
        h2[h2]
        h3[h3]
        h4[h4]
        h5[h5]
        hn[hn]
    end

    TCN1 --> h1
    TCN2 --> h2
    TCN3 --> h3
    TCN4 --> h4
    TCN5 --> h5
    TCNn --> hn

    AttnNet[Gated Attention Network<br/>tanh Vh ⊙ σ Uh]

    h1 --> AttnNet
    h2 --> AttnNet
    h3 --> AttnNet
    h4 --> AttnNet
    h5 --> AttnNet
    hn --> AttnNet

    subgraph Features [Feature Extraction]
        AttnWeights[Attention Weights α]
        EngFeats[Engineered Features:<br/>Amount Spike, Novelty, Rep, etc.]
    end

    AttnNet --> AttnWeights
    AttnNet --> EngFeats

    subgraph Unified_Heads [Unified Prediction Heads]
        direction LR
        subgraph HeadC [Head-C: Account Detection]
            Pooling[Gated Attention Pooling]
            Ensemble[LightGBM + XGBoost Ensemble]
            Pooling --> Ensemble
        end
        subgraph HeadL [Head-L: Transaction Localization]
            Fusion[Feature Fusion α + Feats]
            Ranker[LambdaMART Ranker]
            Fusion --> Ranker
        end
    end

    AttnWeights --> HeadC
    AttnWeights --> HeadL
    EngFeats --> HeadL

    AccountLabel[Account Label:<br/>Scammer / Benign]
    TxRanks[Transaction Ranks:<br/>Phishing / Normal]

    Ensemble --> AccountLabel
    Ranker --> TxRanks

    style Unified_Heads fill:#f9f,stroke:#333,stroke-width:2px
    style HeadC fill:#fff,stroke:#333,stroke-width:1px
    style HeadL fill:#fff,stroke:#333,stroke-width:1px
    style AttnNet fill:#eef,stroke:#333,stroke-width:1px
    style TCN_Layer fill:#f9f9f9,stroke:#333,stroke-width:1px
