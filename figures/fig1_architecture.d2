direction: right

input: {
  label: "Ethereum Account\n(Transaction Bag)"
  shape: rectangle
  style.fill: "#EBF5FB"
  style.stroke: "#2E86C1"
  style.font-size: 14
}

fe: {
  label: "Aggregate Feature Engineering\n(Shared On-Chain Features)"
  shape: rectangle
  style.fill: "#D5F5E3"
  style.stroke: "#1E8449"
  style.font-size: 14
}

account: {
  label: "UnifiedTMIL-Account\n(Aggregate MLP)\n\nX-AUC: 0.984\nHard-AUC: 0.725"
  shape: rectangle
  style.fill: "#FDEBD0"
  style.stroke: "#D35400"
  style.font-size: 13
}

loc: {
  label: "UnifiedTMIL-Loc\n(Feature-Only GBM)\n\nHit@1: 0.832\nMRR: 0.880"
  shape: rectangle
  style.fill: "#F9EBEA"
  style.stroke: "#C0392B"
  style.font-size: 13
}

out1: {
  label: "Account Label\n(Phishing / Benign)"
  shape: oval
  style.fill: "#EBF5FB"
  style.stroke: "#2E86C1"
}

out2: {
  label: "Ranked Transactions\n(Localization)"
  shape: oval
  style.fill: "#EBF5FB"
  style.stroke: "#2E86C1"
}

input -> fe: {label: "raw txns"}
fe -> account: {label: "aggregate\nfeatures"}
fe -> loc: {label: "per-tx\nfeatures"}
account -> out1
loc -> out2
